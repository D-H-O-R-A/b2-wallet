{
  "productName": "B2 Wallet",
  "version": "0.1.3",
  "version_name": "0.1.3 beta",
  "identifier": "com.better2better.b2wallet",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "B2 Wallet - Auto-Custódia Multichain",
        "width": 1024,
